{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@arduconfig/transport": ["packages/transport/src/index.ts"],
      "@arduconfig/protocol-mavlink": ["packages/protocol-mavlink/src/index.ts"],
      "@arduconfig/ardupilot-core": ["packages/ardupilot-core/src/index.ts"],
      "@arduconfig/param-metadata": ["packages/param-metadata/src/index.ts"],
      "@arduconfig/ui-kit": ["packages/ui-kit/src/index.tsx"]
    }
  }
}

